generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  DOCTOR
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NoteStatus {
  DRAFT
  AI_GENERATED
  DOCTOR_REVIEWED
  FINALIZED
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum Dialect {
  NIGERIAN_ENGLISH
  YORUBA_ACCENTED
  HAUSA_ACCENTED
  IGBO_ACCENTED
}

enum ProblemStatus {
  ACTIVE
  RESOLVED
  CHRONIC
  RULE_OUT
}

enum OrderType {
  MEDICATION
  LAB
  IMAGING
  PROCEDURE
  REFERRAL
}

enum OrderStatus {
  PENDING
  ORDERED
  COMPLETED
  CANCELLED
}

enum SummaryLanguage {
  ENGLISH
  PIDGIN
  YORUBA
  HAUSA
  IGBO
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─────────────────────────────────────────────
// DOCTOR-TO-DOCTOR MESSAGING
// ─────────────────────────────────────────────

model Conversation {
  id         String @id @default(uuid())
  hospitalId String
  // Canonical form: userAId < userBId alphabetically, enforced in service layer.
  userAId    String
  userBId    String

  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages DirectMessage[]

  @@unique([hospitalId, userAId, userBId])
  @@index([hospitalId])
  @@index([userAId])
  @@index([userBId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  hospitalId     String

  fromUserId String
  toUserId   String
  content    String

  // Optional context attachment: link a patient or session to the message
  attachedPatientId String?
  attachedSessionId String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([conversationId, createdAt])
  @@index([toUserId, readAt])
  @@index([hospitalId])
  @@map("direct_messages")
}

// ─────────────────────────────────────────────
// MULTI-TENANT CORE
// ─────────────────────────────────────────────

model Hospital {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  address   String?
  phone     String?
  email     String   @unique
  // Optional inbox for the records department. When set, doctors can
  // transfer finalized SOAP notes here via the "Transfer to records" flow.
  recordsEmail String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  doctors  Doctor[]
  patients Patient[]
  sessions ConsultationSession[]
  soapNotes SOAPNote[]

  @@map("hospitals")
}

// ─────────────────────────────────────────────
// AUTH / IDENTITY
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  hospitalId String?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id])

  refreshTokens RefreshToken[]
  doctor        Doctor?
  patient       Patient?
  adminProfile  AdminProfile?

  @@index([email])
  @@index([hospitalId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// ADMIN PROFILE
// ─────────────────────────────────────────────

model AdminProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  firstName  String
  lastName   String
  avatarUrl  String?
  phone      String?
  department String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// DOCTOR
// ─────────────────────────────────────────────

model Doctor {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  hospitalId       String
  hospital         Hospital @relation(fields: [hospitalId], references: [id])

  firstName        String
  lastName         String
  specialization   String
  licenseNumber    String  @unique
  gender           Gender?
  avatarUrl        String?
  phone            String?
  bio              String?

  preferredDialect Dialect @default(NIGERIAN_ENGLISH)
  isAvailable      Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  schedules DoctorSchedule[]
  sessions  ConsultationSession[]

  @@index([hospitalId])
  @@map("doctors")
}

model DoctorSchedule {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, dayOfWeek])
  @@map("doctor_schedules")
}

// ─────────────────────────────────────────────
// PATIENT
// ─────────────────────────────────────────────

model Patient {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  hospitalId        String
  hospital          Hospital  @relation(fields: [hospitalId], references: [id])

  firstName         String
  lastName          String
  dateOfBirth       DateTime?
  gender            Gender?
  bloodGroup        String?
  genotype          String?
  phone             String?
  address           String?
  nextOfKin         String?
  nextOfKinPhone    String?
  avatarUrl         String?

  medicalRecordNo   String?   @unique
  allergies         String[]
  chronicConditions String[]

  preferTTS         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions  ConsultationSession[]
  soapNotes SOAPNote[]

  @@index([hospitalId])
  @@index([medicalRecordNo])
  @@map("patients")
}

// ─────────────────────────────────────────────
// CONSULTATION SESSION
// ─────────────────────────────────────────────

model ConsultationSession {
  id         String        @id @default(uuid())
  hospitalId String
  hospital   Hospital      @relation(fields: [hospitalId], references: [id])
  doctorId   String
  doctor     Doctor        @relation(fields: [doctorId], references: [id])
  patientId  String
  patient    Patient       @relation(fields: [patientId], references: [id])

  status      SessionStatus @default(SCHEDULED)
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  dialect     Dialect       @default(NIGERIAN_ENGLISH)

  roomToken String? @unique
  notes     String?

  handoverNote         String?
  originalDoctorId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transcriptions Transcription[]
  soapNote       SOAPNote?

  @@index([hospitalId])
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@map("consultation_sessions")
}

// ─────────────────────────────────────────────
// TRANSCRIPTION
// ─────────────────────────────────────────────

model Transcription {
  id        String              @id @default(uuid())
  sessionId String
  session   ConsultationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  text       String
  confidence Float?
  speakerTag String?
  startMs    Int?
  endMs      Int?
  dialect    Dialect

  syncStatus SyncStatus @default(SYNCED)
  createdAt  DateTime   @default(now())

  @@index([sessionId])
  @@map("transcriptions")
}

// ─────────────────────────────────────────────
// SOAP NOTE
// ─────────────────────────────────────────────

model SOAPNote {
  id         String              @id @default(uuid())
  sessionId  String              @unique
  session    ConsultationSession @relation(fields: [sessionId], references: [id])
  hospitalId String
  hospital   Hospital            @relation(fields: [hospitalId], references: [id])
  patientId  String
  patient    Patient             @relation(fields: [patientId], references: [id])

  subjective String
  objective  String
  assessment String
  plan       String

  status        NoteStatus @default(AI_GENERATED)
  aiModel       String?    @default("claude-sonnet-4-6")
  promptVersion String?

  ttsAudioUrl    String?
  ttsGeneratedAt DateTime?
  drugWarnings   String?   // JSON: string[] of interaction warnings

  doctorSignedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  problems        Problem[]
  orders          Order[]
  billingCodes    BillingCode[]
  patientSummaries PatientSummary[]

  @@index([hospitalId])
  @@index([patientId])
  @@map("soap_notes")
}

model NoteChatMessage {
  id         String   @id @default(uuid())
  sessionId  String?
  patientId  String?
  hospitalId String
  soapNoteId String?

  role    ChatRole
  content String

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([patientId, createdAt])
  @@index([hospitalId])
  @@map("note_chat_messages")
}

model PatientSummary {
  id         String          @id @default(uuid())
  soapNoteId String
  soapNote   SOAPNote        @relation(fields: [soapNoteId], references: [id], onDelete: Cascade)
  hospitalId String
  patientId  String

  language   SummaryLanguage @default(ENGLISH)
  content    String          // Plain-language markdown
  edited     Boolean         @default(false)

  sentVia    String[]        // ["EMAIL", "WHATSAPP", "SMS", "PRINT"]
  sentAt     DateTime?

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([soapNoteId])
  @@index([patientId])
  @@index([hospitalId])
  @@map("patient_summaries")
}

// ─────────────────────────────────────────────
// EHR STRUCTURED EXTRACTIONS
// ─────────────────────────────────────────────

model Problem {
  id         String        @id @default(uuid())
  soapNoteId String
  soapNote   SOAPNote      @relation(fields: [soapNoteId], references: [id], onDelete: Cascade)
  hospitalId String
  patientId  String

  name       String
  icd10Code  String?
  status     ProblemStatus @default(ACTIVE)
  notes      String?

  source     String        @default("AI_EXTRACTED") // AI_EXTRACTED | DOCTOR_ADDED | DOCTOR_EDITED
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  billingCodes BillingCode[]

  @@index([soapNoteId])
  @@index([patientId])
  @@index([hospitalId])
  @@map("problems")
}

model Order {
  id         String       @id @default(uuid())
  soapNoteId String
  soapNote   SOAPNote     @relation(fields: [soapNoteId], references: [id], onDelete: Cascade)
  hospitalId String
  patientId  String

  type         OrderType
  name         String
  dosage       String?
  frequency    String?
  duration     String?
  instructions String?
  status       OrderStatus @default(PENDING)

  source    String   @default("AI_EXTRACTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billingCodes BillingCode[]

  @@index([soapNoteId])
  @@index([patientId])
  @@index([hospitalId])
  @@map("orders")
}

model BillingCode {
  id         String   @id @default(uuid())
  soapNoteId String
  soapNote   SOAPNote @relation(fields: [soapNoteId], references: [id], onDelete: Cascade)
  hospitalId String
  patientId  String

  problemId  String?
  problem    Problem? @relation(fields: [problemId], references: [id], onDelete: Cascade)

  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  codeType    String // ICD10 | SNOMED | CPT | NHIA
  code        String
  description String
  tariffNgn   Int?     // Naira amount when codeType=NHIA
  isSelected  Boolean  @default(false)

  source    String   @default("AI_EXTRACTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([soapNoteId])
  @@index([hospitalId])
  @@index([problemId, codeType])
  @@index([orderId, codeType])
  @@map("billing_codes")
}

// ─────────────────────────────────────────────
// OFFLINE SYNC QUEUE
// ─────────────────────────────────────────────

model OfflineSyncQueue {
  id         String     @id @default(uuid())
  userId     String
  hospitalId String
  entityType String
  payload    Json
  syncStatus SyncStatus @default(PENDING)
  attempts   Int        @default(0)
  lastError  String?
  createdAt  DateTime   @default(now())
  syncedAt   DateTime?

  @@index([userId, syncStatus])
  @@map("offline_sync_queue")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  hospitalId String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([hospitalId])
  @@index([createdAt])
  @@map("audit_logs")
}
