# Server
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://meditir_user:password@localhost:5432/meditir_db

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change_me_min_32_chars_access_secret_here
JWT_REFRESH_SECRET=change_me_different_32_chars_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_SECRET=change_me_min_16_chars
COOKIE_DOMAIN=localhost

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Anthropic (Claude SOAP note generation) — REQUIRED
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
SOAP_PROMPT_VERSION=v1.0.0

# ElevenLabs (TTS audio for patients) — optional
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Logging
LOG_LEVEL=debug
